{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openfang.dev/schemas/claude-feedback.schema.json",
  "title": "ClaudeFeedbackPayload",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "head_sha",
    "findings"
  ],
  "properties": {
    "head_sha": {
      "type": "string",
      "minLength": 7
    },
    "summary": {
      "type": "string"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "severity",
          "confidence",
          "path",
          "line",
          "summary"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low",
              "info"
            ]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "line": {
            "type": "integer",
            "minimum": 1
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "actionable": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
